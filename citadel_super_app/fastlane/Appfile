# For more information about the Appfile, see:
# https://docs.fastlane.tools/advanced/#appfile

# Android
json_key_file(ENV['PLAY_STORE_CREDENTIAL_PATH']) # Path to the json secret file - Follow https://docs.fastlane.tools/actions/supply/#setup to get one
package_name(ENV['APP_ID'])

# IOS
app_identifier(ENV['BUNDLE_ID']) # The bundle identifier of your app
apple_id(ENV['APPLE_ID']) # Your Apple email address
itc_team_id(ENV['ITC_TEAM_ID']) # App Store Connect Team ID
team_id(ENV['TEAM_ID']) # Developer Portal Team ID
